                <div class="modal-content rounded-3 shadow">
                    <div class="modal-header bg-primary">
                        <h5 class="modal-title" id="fabrikasiModalLabel">Fabrikasi</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                    </div>
                    <div class="modal-body">
                        <form method="post" action="/AdminFabrication/Request/AddFabrikasi">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="RepeatOrderId" value="@ir.Id" />
                            <input type="hidden" name="ItemRequestId" value="@ir.ItemRequests.Id" />
