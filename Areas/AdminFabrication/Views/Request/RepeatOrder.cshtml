                                <label for="MachineId" class="mb-2">Mesin Fabrikasi</label>
                                @await Component.InvokeAsync("MachineList", new { selectedId = ir.ItemRequests.MachineCategoryId })
                                <span asp-validation-for="Machine" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label for="Quantity" class="mb-2">Quantity</label>
                                <input name="Quantity" type="number" min="1" max="@ir.QuantityReq" placeholder="Masukan jumlah" class="form-control" required />
