@model List<EWOS_MVC.Models.RepeatOrderModel>
@{
    ViewData["Title"] = "Request List";
}
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h5 class="my-3">Request List</h5>
@if (TempData["Error"] != null || TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @(TempData["Error"] ?? TempData["ErrorMessage"])
    </div>
}
<div class="row mb-3">
    <div class="col-2 col-sm-2">
        @await Component.InvokeAsync("MachineCategories")
    </div>
    <div class="col-4 col-sm-4">
        <input type="text" id="searchBox" class="form-control" placeholder="Search..." aria-label="Search">
    </div>
</div>


<div class="tab-wrapper">

    @{
        var summary = ViewBag.StatusSummary as Dictionary<string, int>;
        int GetCount(string status) => summary != null && summary.ContainsKey(status) ? summary[status] : 0;
    }
    <!-- Tab Bar-->
    <ul class="nav nav-tabs justify-content-center" id="statusTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="waitingapproval-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#waitingapproval"
                    data-status="WaitingApproval"
                    type="button"
                    role="tab">
                Supervisor Approval
                @if (GetCount("WaitingApproval") > 0)
                {
                    <span class="badge bg-danger rounded-pill">@GetCount("WaitingApproval")</span>
                }
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="fabricationapproval-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#FabricationApproval"
                    data-status="FabricationApproval"
                    type="button"
                    role="tab">
                Fabrication Approval
                @if (GetCount("FabricationApproval") > 0)
                {
                    <span class="badge bg-danger rounded-pill">@GetCount("FabricationApproval")</span>
                }
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="waitingfabrication-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#WaitingFabrication"
                    data-status="WaitingFabrication"
                    type="button"
                    role="tab">
                Waiting Fabrication
                @if (GetCount("WaitingFabrication") > 0)
                {
                    <span class="badge bg-danger rounded-pill">@GetCount("WaitingFabrication")</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="infabrication-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#InFabrication"
                    data-status="InFabrication"
                    type="button"
                    role="tab">
                In Fabrication
                @if (GetCount("InFabrication") > 0)
                {
                    <span class="badge bg-danger rounded-pill">@GetCount("InFabrication")</span>
                }
            </button>
        </li>
        
    </ul>
</div>

<!-- Table data-->
<table class="table table-sm table-striped table-bordered mt-3">
    <thead>
        <tr>
            <th class="text-center">No</th>
            <th>Requestor</th>
            <th>Part Name</th>
            <th>Request Category</th>
            <th>CRD</th>
            <th>Request Date</th>
            <th class="text-center">Action</th>
        </tr>
    </thead>
    <tbody>
        @{
            int index = 1;
        }
        <tr id="loadingText" style="display:none; text-align:center; margin-bottom:10px; font-weight:bold; color:#555;">
            <td>Loading...</td>
        </tr>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted">Tidak ada data Requeast.</td>
            </tr>
        }
        else
        {
            foreach (var rq in Model)
            {
                <tr>
                    <td class="text-center">@index</td>
                    <td>@rq.Users.Name</td>
                    <td>@rq.ItemRequests.PartName</td>
                    <td>@rq.ItemRequests?.MachineCategories?.CategoryName</td>
                    <td>@rq.CRD.ToString("dd/MM/yyyy")</td>
                    <td>@rq.CreatedAt</td>
                    <td>@rq.CRD.ToString("dd/MM/yyyy")</td>
                    <td>@rq.CreatedAt</td>
                    <td class="text-center">
                        @if (rq.Status == "ApprovalFabrication")
                        {
                         
                            <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalApprove-@rq.Id">
                                Approve
                            </button>
                            @* <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#modalReject-@rq.Id">
                                Reject
                            </button> *@
                        }
                        else if (rq.Status == "WaitingFabrication")
                        {

                                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#fabrikasiModal-@rq.Id">
                                    Fabrikasi
                                </button>
                        }

                        <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#modalDetail-@rq.Id">
                            Detail
                        </button>

                    </td>

                </tr>
                index++;
            }
        }
    </tbody>
</table>

 @if (ViewBag.ModalData != null)
{
    foreach (var ir in (IEnumerable<dynamic>)ViewBag.ModalData)
    {
        <!-- Modal Approve -->
        <div class="modal fade" id="modalApprove-@ir.Id" tabindex="-1" aria-labelledby="editLabel-@ir.Id" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" action="/AdminFabrication/Request/Approve" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="modal-header bg-success">
                            <h5 class="modal-title mb-2 text-white" id="modalApprove">Approve Request</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                        </div>
                        <div class="modal-body">
                            <div class="form-group">
                                <label class="my-2" asp-for="ItemRequestId">Id Request</label>
                                <input class="form-control" value="@ir.Id" readonly />
                                <span asp-validation-for="PartName" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label class="my-2" asp-for="ItemRequestId">Item Name</label>
                                <input type="hidden" name="RepeatOrderId" value="@ir.Id" />
                                <input type="hidden" name="ItemRequestId" value="@ir.ItemRequests.Id" />
                                <input name="PartName" class="form-control" value="@ir.ItemRequests.PartName" readonly />
                                <span asp-validation-for="PartName" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label class="my-2" asp-for="OCD">Prediction Complete</label>
                                <input name="OCD" type="date" class="form-control" value="" required />
                                <span asp-validation-for="OCD" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                            <button type="submit" class="btn btn-success">Approve</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
