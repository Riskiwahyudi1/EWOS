@{
    ViewData["Title"] = "Home Page";
}


<style>
    body {
        background: linear-gradient(135deg, #e9eef7 0%, #ffffff 100%);
        min-height: 100vh;
    }

    .dashboard-title {
        font-weight: 700;
        color: #2a2d3e;
        margin-top: 20px;
        letter-spacing: 1px;
    }

    /* Card Modern */
    .stat-card {
        transition: 0.3s ease-in-out;
        border: none;
        border-radius: 15px;
    }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        }

    .icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 10px;
    }

    /* Panduan */
    .guide-card {
        border-radius: 15px;
    }
</style>


<div class="container py-5 text-center">

    <h3 class="display-5 dashboard-title">Welcome to Inhouse Fabrication System</h3>
    <p class="text-muted">Dashboard ringkas & informatif untuk monitoring proses fabrikasi</p>

    <div class="container mt-4">

        <div class="row g-4 justify-content-center">

            <!-- Total Request Fabrikasi -->
            <div class="col-md-4">
                <div class="card stat-card shadow-sm p-3">
                    <div class="card-body text-center">
                        <div class="icon-wrapper bg-primary text-white shadow-sm">
                            <i class="bi bi-clipboard-plus"></i>
                        </div>
                        <h6 class="text-secondary mb-1">Total Request Fabrikasi</h6>
                        <h2 class="fw-bold text-primary">125</h2>
                    </div>
                </div>
            </div>

            <!-- Total Repeat Order -->
            <div class="col-md-4">
                <div class="card stat-card shadow-sm p-3">
                    <div class="card-body text-center">
                        <div class="icon-wrapper bg-warning text-white shadow-sm">
                            <i class="bi bi-repeat"></i>
                        </div>
                        <h6 class="text-secondary mb-1">Total Repeat Order</h6>
                        <h2 class="fw-bold text-warning">45</h2>
                    </div>
                </div>
            </div>

            <!-- Fabrikasi Selesai -->
            <div class="col-md-4">
                <div class="card stat-card shadow-sm p-3">
                    <div class="card-body text-center">
                        <div class="icon-wrapper bg-success text-white shadow-sm">
                            <i class="bi bi-check-circle"></i>
                        </div>
                        <h6 class="text-secondary mb-1">Fabrikasi Selesai</h6>
                        <h2 class="fw-bold text-success">98</h2>
                    </div>
                </div>
            </div>

        </div>

        <!-- Panduan Penggunaan -->
        <div class="card shadow-sm border-0 guide-card mt-5 p-4">
            <h4 class="text-primary"><i class="bi bi-info-circle"></i> Panduan Penggunaan System</h4>
            <hr>

            <h5 class="mt-3 text-primary text-start"><i class="bi bi-plus-circle"></i> Request Baru</h5>
            <ol class="text-start mb-4">
                <li>Buka menu <strong>Form Request</strong> untuk membuat request fabrikasi baru.</li>
                <li>Isi seluruh data item yang ingin difabrikasi (nama produk, spesifikasi, jumlah, tanggal butuh, dsb).</li>
                <li>Klik <strong>Submit</strong> untuk mengirim request ke bagian fabrikasi.</li>
            </ol>

            <h5 class="mt-3 text-warning text-start"><i class="bi bi-arrow-repeat"></i> Repeat Order</h5>
            <ol class="text-start mb-4">
                <li>Buka menu <strong>Repeat Order</strong> atau <strong>List Product</strong>.</li>
                <li>Gunakan kolom pencarian untuk mencari produk yang sudah pernah difabrikasi.</li>
                <li>Pilih produk yang ingin di-repeat.</li>
                <li>Klik tombol <strong>Request</strong> lalu masukan jumlah dan tanggal butuh.</li>
                <li>Submit permintaan repeat order.</li>
            </ol>

            <h5 class="mt-3 text-success text-start"><i class="bi bi-eye"></i> Melihat Status Saya</h5>
            <ol class="text-start mb-4">
                <li>Buka menu <strong>Tracking Fabrikasi</strong>.</li>
                <li>Lihat seluruh status pekerjaan: pending, proses, atau selesai.</li>
                <li>Jika pekerjaan selesai, sistem otomatis memindahkan ke bagian <strong>Fabrikasi Selesai</strong>.</li>
                <li>Pada menu <strong>Laporan</strong>, Anda dapat mengunduh riwayat pekerjaan Anda.</li>
            </ol>
        </div>

    </div>
</div>
